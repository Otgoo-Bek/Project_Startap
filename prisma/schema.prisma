generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(uuid())
  uid                 String        @unique
  email               String        @unique
  role                String
  name                String?
  phone               String?
  pushToken           String?
  experience          String?
  isHot               Boolean       @default(false)
  aiScore             Float         @default(0)
  ratingCount         Int           @default(0)
  address             String?
  photoUrl            String?
  companyName         String?
  responsibleName     String?
  location            String?
  yearsOnMarket       Int?
  specialties         String?
  employerRating      Float?
  employerRatingCount Int           @default(0)
  earnings            Int           @default(0)
  shiftsCreated       Shift[]
  applications        Application[]
  reviewsGiven        Review[]      @relation("ReviewFrom")
  reviewsReceived     Review[]      @relation("ReviewTo")
  documents           Document[]
  transactionsFrom    Transaction[] @relation("TransactionFrom")
  transactionsTo      Transaction[] @relation("TransactionTo")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Shift {
  id            String        @id @default(uuid())
  role          String
  establishment String
  address       String
  startTime     DateTime
  pay           Int
  description   String?
  status        String        @default("OPEN")
  creator       User          @relation(fields: [creatorId], references: [id])
  creatorId     String
  applications  Application[]
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
}

model Application {
  id        String   @id @default(uuid())
  status    String   @default("PENDING")
  comment   String?
  rating    Int?
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId   String
  seeker    User     @relation(fields: [seekerId], references: [id])
  seekerId  String
  createdAt DateTime @default(now())
  @@unique([shiftId, seekerId])
}

model Review {
  id         String   @id @default(uuid())
  fromUser   User     @relation("ReviewFrom", fields: [fromUserId], references: [id])
  fromUserId String
  toUser     User     @relation("ReviewTo", fields: [toUserId], references: [id])
  toUserId   String
  text       String
  stars      Int
  createdAt  DateTime @default(now())
}

model Document {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  name      String
  url       String
  type      String   @default("document")
  createdAt DateTime @default(now())
}

model Transaction {
  id         String   @id @default(uuid())
  fromUser   User?    @relation("TransactionFrom", fields: [fromUserId], references: [id])
  fromUserId String?
  toUser     User?    @relation("TransactionTo", fields: [toUserId], references: [id])
  toUserId   String?
  shift      Shift?   @relation(fields: [shiftId], references: [id])
  shiftId    String?
  amount     Int
  type       String
  description String?
  status     String   @default("COMPLETED")
  createdAt  DateTime @default(now())
}