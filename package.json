{
  "name": "asap-horeca-backend",
  "version": "1.0.0",
  "description": "ASAP HORECA Backend API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "build": "tsc --skipLibCheck",
    "start": "node dist/server.js",
    "dev": "ts-node --transpile-only src/server.ts",
    "dev:watch": "nodemon --exec 'ts-node --transpile-only src/server.ts'"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "prisma": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
